{
  "meta": {
    "name": "Neon Blackout — DTCG Tokens",
    "version": "1.0",
    "description": "Canonical token source. All UI values reference this file.",
    "author": "Anna",
    "updated": "2026-07-01"
  },
  "color": {
    "void": { "$value": "#050507", "$type": "color", "description": "Primary background" },
    "elev": { "$value": "#12131c", "$type": "color", "description": "Cards, panels, elevated surfaces" },
    "raised": { "$value": "#1a1a2e", "$type": "color", "description": "Transient UI only (modals, dropdowns, popovers)" },
    "fg": { "$value": "#cfc8ee", "$type": "color", "description": "Primary text color — lavender" },
    "muted": { "$value": "#8e88ab", "$type": "color", "description": "Secondary text, labels" },
    "line": { "$value": "rgba(207,200,238,0.14)", "$type": "color", "description": "Borders, dividers" },
    "line-soft": { "$value": "rgba(207,200,238,0.07)", "$type": "color", "description": "Subtle dividers" },

    "resistance-magenta": { "$value": "#ff00aa", "$type": "color", "description": "Primary action, brand" },
    "transition-cyan": { "$value": "#00fff0", "$type": "color", "description": "Focus, cursor, active indicator" },
    "lifeblood-red": { "$value": "#ff3864", "$type": "color", "description": "Errors, destructive actions, danger" },
    "autonomy-yellow": { "$value": "#ffd800", "$type": "color", "description": "Warnings, caution" },
    "pulse-green": { "$value": "#39ff14", "$type": "color", "description": "Success, confirmed, passing" },
    "mending-orange": { "$value": "#ff9f1c", "$type": "color", "description": "Staged, intermediate" },
    "harmony-blue": { "$value": "#00aaff", "$type": "color", "description": "Info, structural accents" },
    "spirit-violet": { "$value": "#7b3fd4", "$type": "color", "description": "Accent — large text only (3.40:1 on void)" },
    "wholeness-violet": { "$value": "#c20ff0", "$type": "color", "description": "Intersex circle, decorative only" },
    "becoming-white": { "$value": "#ffffff", "$type": "color", "description": "Flag color, NOT UI text (use --fg)" }
  },
  "spacing": {
    "4": { "$value": "4px", "$type": "dimension" },
    "8": { "$value": "8px", "$type": "dimension" },
    "16": { "$value": "16px", "$type": "dimension" },
    "24": { "$value": "24px", "$type": "dimension" },
    "32": { "$value": "32px", "$type": "dimension" },
    "48": { "$value": "48px", "$type": "dimension" },
    "64": { "$value": "64px", "$type": "dimension" }
  },
  "border-radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "font-family": {
    "display": { "$value": ["Audiowide", "sans-serif"], "$type": "fontFamily" },
    "body": { "$value": ["SpaceGroteskVF", "system-ui", "sans-serif"], "$type": "fontFamily" },
    "mono": { "$value": ["SpaceMono", "monospace"], "$type": "fontFamily" }
  },
  "font-size": {
    "body": { "$value": "16px", "$type": "fontSize" },
    "ui-label": { "$value": "0.8rem", "$type": "fontSize" },
    "code": { "$value": "0.8rem", "$type": "fontSize" }
  },
  "opacity": {
    "disabled": { "$value": "0.35", "$type": "opacity" },
    "line": { "$value": "0.14", "$type": "opacity" },
    "line-soft": { "$value": "0.07", "$type": "opacity" }
  }
}
