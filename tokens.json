{
  "meta": {
    "name": "Neon Blackout",
    "version": "1.0",
    "description": "A cyberpunk/synthwave design system mapped to the Intersex-Inclusive Progress Pride flag. High-contrast neon on near-black.",
    "author": "Anna",
    "updated": "2026-06-30",
    "license": "CC0 / free to use"
  },

  "surfaces": {
    "description": "Background and foreground layers. Void-first — color is spent, never sprayed.",
    "colors": {
      "bg":        { "hex": "#050507", "name": "Void",         "usage": "Primary background" },
      "bg-elev":   { "hex": "#12131c", "name": "Elevated",     "usage": "Cards, panels, elevated surfaces" },
      "fg":        { "hex": "#cfc8ee", "name": "Lavender Fg",  "usage": "Primary text color" },
      "muted":     { "hex": "#8e88ab", "name": "Muted",        "usage": "Secondary text, labels, captions" },
      "selection": { "hex": "#3a1330", "name": "Selection",    "usage": "Text selection highlight" },
      "cursor":    { "hex": "#00fff0", "name": "Cursor",       "usage": "Input cursor, terminal caret" },
      "line":      { "hex": "rgba(207,200,238,0.14)", "name": "Line",      "usage": "Borders, dividers" },
      "line-soft": { "hex": "rgba(207,200,238,0.07)", "name": "Line Soft", "usage": "Subtle dividers" }
    }
  },

  "ansi": {
    "description": "Standard ANSI c0–c15 terminal palette. Ships in this order for terminal themes.",
    "colors": {
      "c0":  { "hex": "#12131c", "name": "Black",        "ansi": 0  },
      "c1":  { "hex": "#ff3864", "name": "Red",          "ansi": 1  },
      "c2":  { "hex": "#39ff14", "name": "Green",        "ansi": 2  },
      "c3":  { "hex": "#fcee09", "name": "Yellow",       "ansi": 3  },
      "c4":  { "hex": "#00aaff", "name": "Blue",         "ansi": 4  },
      "c5":  { "hex": "#ff00aa", "name": "Magenta",      "ansi": 5  },
      "c6":  { "hex": "#00fff0", "name": "Cyan",         "ansi": 6  },
      "c7":  { "hex": "#cfc8ee", "name": "White",        "ansi": 7  },
      "c8":  { "hex": "#4a4a5c", "name": "Bright Black", "ansi": 8  },
      "c9":  { "hex": "#ff8fd8", "name": "Bright Red",   "ansi": 9  },
      "c10": { "hex": "#9dff7a", "name": "Bright Green", "ansi": 10 },
      "c11": { "hex": "#fff9b0", "name": "Bright Yellow","ansi": 11 },
      "c12": { "hex": "#5ad4ec", "name": "Bright Blue",  "ansi": 12 },
      "c13": { "hex": "#7b3fd4", "name": "Bright Magenta","ansi": 13 },
      "c14": { "hex": "#7dfff5", "name": "Bright Cyan",  "ansi": 14 },
      "c15": { "hex": "#ffffff", "name": "Bright White", "ansi": 15 }
    }
  },

  "heritage": {
    "description": "13 heritage colors mapped from the Intersex-Inclusive Progress Pride flag. Read left-to-right: intersex → chevron (tip→outer) → rainbow (top→bottom).",
    "swatches": [
      { "name": "Intersex Yellow", "hex": "#ffd800", "represents": "free of the binary",              "ansi": "flag" },
      { "name": "Intersex Purple", "hex": "#c20ff0", "represents": "wholeness · autonomy",             "ansi": "tuned" },
      { "name": "White",           "hex": "#ffffff", "represents": "trans · nonbinary",                "ansi": "c15" },
      { "name": "Trans Pink",      "hex": "#ff8fd8", "represents": "trans community",                 "ansi": "c9" },
      { "name": "Trans Blue",      "hex": "#5ad4ec", "represents": "trans community",                 "ansi": "c12" },
      { "name": "Brown",           "hex": "#c98745", "represents": "people of color",                  "ansi": "copper" },
      { "name": "Black",           "hex": "#12131c", "represents": "POC · lives lost to AIDS",        "ansi": "c0" },
      { "name": "Life",            "hex": "#ff3864", "represents": "red · rainbow",                   "ansi": "c1" },
      { "name": "Healing",         "hex": "#ff9f1c", "represents": "orange · rainbow (reintroduced from Chrome Static)", "ansi": "orig" },
      { "name": "Sunlight",        "hex": "#fcee09", "represents": "yellow · rainbow",                "ansi": "c3" },
      { "name": "Nature",          "hex": "#39ff14", "represents": "green · rainbow",                 "ansi": "c2" },
      { "name": "Harmony",         "hex": "#00aaff", "represents": "blue · rainbow",                  "ansi": "c4" },
      { "name": "Spirit",          "hex": "#7b3fd4", "represents": "violet · rainbow",                "ansi": "c13" }
    ]
  },

  "signature": {
    "description": "Cyberpunk signature neons. No flag meaning; they define the aesthetic.",
    "swatches": [
      { "name": "Static Magenta", "hex": "#ff00aa", "represents": "brand · primary action", "ansi": "c5" },
      { "name": "Signal Cyan",    "hex": "#00fff0", "represents": "focus · active accent",  "ansi": "c6" }
    ]
  },

  "extended": {
    "description": "Extended colors outside the standard ANSI slots. Some carry flag meaning, some are from the original Chrome Static palette.",
    "colors": {
      "copper":    { "hex": "#c98745", "source": "original ANSI (non-standard)", "note": "Brown stripe — people of color (flag)" },
      "orange":    { "hex": "#ff9f1c", "source": "reintroduced from Chrome Static", "note": "Healing — orange rainbow stripe (flag)" },
      "ix-yellow": { "hex": "#ffd800", "source": "intersex flag canonical (Carpenter 2013)", "note": "Intersex field yellow" },
      "ix-purple": { "hex": "#c20ff0", "source": "neon-tuned from canonical #7902aa", "note": "Intersex circle. Pushed warmer to distinguish from Spirit violet #7b3fd4" },
      "lifeblood-red-deep": {
        "hex": "#cf133c",
        "status": "deprecated",
        "usage": "Decorative backgrounds only (tags, filled buttons with white text). Do NOT use for text on void."
      }
    }
  },

  "semantics": {
    "description": "Color-to-meaning mapping. Every hue has a semantic role — don't use them interchangeably.",
    "roles": {
      "primary":   { "hex": "#ff00aa", "token": "c5",  "name": "Magenta", "usage": "Brand, primary action buttons, key highlights" },
      "error":     { "hex": "#ff3864", "token": "c1",  "name": "Red",     "usage": "Errors, destructive actions, alerts" },
      "warning":   { "hex": "#ffd800", "token": "c3",  "name": "Yellow",  "usage": "Warnings, caution states" },
      "info":      { "hex": "#00aaff", "token": "c4",  "name": "Blue",    "usage": "Informational elements, links, structural accents" },
      "success":   { "hex": "#39ff14", "token": "c2",  "name": "Green",   "usage": "Success states, confirmed status, passing tests" },
      "focus":     { "hex": "#00fff0", "token": "c6",  "name": "Cyan",    "usage": "Focus rings, active element, cursor. Use sparingly — it reads as energy everywhere" },
      "destructive": { "hex": "#ff3864", "token": "c1", "name": "Red",    "usage": "Destructive actions (error alias)" }
    }
  },

  "typography": {
    "description": "Three-role type system. Audiowide for display, Space Grotesk for body, JetBrains Mono for code/labels. Loaded from Google Fonts.",
    "font-family": {
      "display": { "family": "Audiowide",     "fallback": "sans-serif",              "weights": [500, 700, 900], "note": "Display, wordmarks, headings. Use with restraint." },
      "body":    { "family": "Space Grotesk","fallback": "system-ui, sans-serif",    "weights": [400, 500, 700], "note": "Body text, prose." },
      "mono":    { "family": "JetBrains Mono","fallback": "monospace",               "weights": [400, 500, 700], "note": "Code, labels, data, terminal register." }
    },
    "sizes": {
      "hero":       { "size": "clamp(2.6rem, 9vw, 6rem)",     "weight": 900, "line-height": "0.95",  "family": "display" },
      "h2":         { "size": "clamp(1.3rem, 3vw, 1.9rem)",   "weight": 700, "line-height": null,    "family": "display" },
      "body":       { "size": "1rem",                         "weight": 400, "line-height": "1.6",    "family": "body" },
      "body-large": { "size": "1.15rem",                      "weight": 400, "line-height": null,     "family": "body" },
      "mono":       { "size": "0.95rem",                      "weight": 500, "line-height": null,     "family": "mono" },
      "eyebrow":    { "size": "0.72rem",                      "weight": 500, "letter-spacing": "0.32em", "family": "mono", "transform": "uppercase" },
      "label":      { "size": "0.72rem",                      "weight": 400, "letter-spacing": "0.1em",  "family": "mono", "transform": "uppercase" },
      "button":     { "size": "0.78rem",                      "weight": 400, "letter-spacing": "0.08em", "family": "mono", "transform": "uppercase" },
      "tag":        { "size": "0.7rem",                       "weight": 400, "family": "mono" },
      "hex":        { "size": "0.7rem",                       "weight": 400, "family": "mono" },
      "ansi-label": { "size": "0.6rem",                       "weight": 400, "family": "mono", "letter-spacing": "0.06em" },
      "footnote":   { "size": "0.85rem",                      "weight": 400, "family": "mono" }
    }
  },

  "spacing": {
    "description": "8px-base spacing scale. All values derive from 0.5rem (8px) increments. Use these tokens instead of arbitrary rem values. Pixel values at 16px base.",
    "scale": {
      "--space-4":  { "rem": "0.25rem", "px": 4,  "usage": "Tag inner Y, tight gaps, panel bar gaps" },
      "--space-8":  { "rem": "0.5rem",  "px": 8,  "usage": "Button Y, input Y, tag X, list item Y, panel bar Y" },
      "--space-12": { "rem": "0.75rem", "px": 12, "usage": "Button X, input X, list item X, demo gaps, medium gaps" },
      "--space-16": { "rem": "1rem",    "px": 16, "usage": "Divider margin, section head gap, spec body gap" },
      "--space-24": { "rem": "1.5rem",  "px": 24, "usage": "Panel body, spec body padding, demo grid gaps" },
      "--space-32": { "rem": "2rem",    "px": 32, "usage": "Page padding, section spacing" },
      "--space-40": { "rem": "2.5rem",  "px": 40, "usage": "Section spacing (tight)" },
      "--space-48": { "rem": "3rem",    "px": 48, "usage": "Section spacing, footer top" },
      "--space-64": { "rem": "4rem",    "px": 64, "usage": "Footer spacing, hero bottom" },
      "--space-80": { "rem": "5rem",    "px": 80, "usage": "Header top, hero sections" },
      "--space-96": { "rem": "6rem",    "px": 96, "usage": "Page sections, generous hero spacing" }
    }
  },

  "border-radius": {
    "description": "Border radius tokens. --radius-md (6px) is the default for interactive elements. --radius-lg (10px) is for containers.",
    "tokens": {
      "--radius-sm":   { "px": 4,   "usage": "Subtle corners, list items, decorative elements" },
      "--radius-md":   { "px": 6,   "usage": "Buttons, inputs, toasts — default interactive radius" },
      "--radius-lg":   { "px": 10,  "usage": "Panels, cards, spec containers, elevated surfaces" },
      "--radius-full": { "px": 999, "usage": "Pills, tags, badges — fully rounded ends on rectangles" }
    },
    "utilities": {
      ".circle": { "description": "Forces a perfect circle: border-radius: 50% + aspect-ratio: 1. Use on avatars, status dots, indicator icons. Works on any element with defined dimensions." }
    }
  },

  "components": {
    "description": "Component styles observed from the HTML. **Not yet documented as reusable specs — this is a structural placeholder for task 3.**",
    "definitions": {
      "button": {
        "variants": ["primary", "ghost", "warn"],
        "base": {
          "font-family": "mono",
          "font-size": "0.78rem",
          "letter-spacing": "0.08em",
          "text-transform": "uppercase",
          "padding": "var(--space-8) var(--space-16)",
          "border-radius": "var(--radius-md)",
          "border": "none",
          "cursor": "pointer"
        },
        "variants": {
          "primary": { "background": "c5", "color": "#2b0020", "box-shadow": "0 0 16px rgba(255,0,170,0.5)" },
          "ghost":   { "background": "transparent", "color": "c6", "border": "1px solid var(--c6)" },
          "warn":    { "background": "c3", "color": "#3a2f00" }
        }
      },
      "input": {
        "base": {
          "background": "bg",
          "border": "1px solid var(--line)",
          "border-radius": "var(--radius-md)",
          "padding": "var(--space-8) var(--space-12)",
          "color": "fg",
          "font-family": "mono",
          "font-size": "0.85rem"
        },
        "focus": {
          "outline": "none",
          "border-color": "c6",
          "box-shadow": "0 0 0 2px rgba(0,255,240,0.2)"
        }
      },
      "tag": {
        "base": {
          "font-family": "mono",
          "font-size": "0.78rem",
          "padding": "var(--space-4) var(--space-8)",
          "border-radius": "var(--radius-full)"
        }
      },
      "panel": {
        "base": {
          "border": "1px solid var(--line)",
          "border-radius": "var(--radius-lg)",
          "background": "bg-elev",
          "overflow": "hidden"
        },
        "bar-top": {
          "padding": "var(--space-8) var(--space-16)",
          "border-bottom": "1px solid var(--line-soft)",
          "gap": "var(--space-4)"
        },
        "body": {
          "padding": "var(--space-24)"
        }
      },
      "toast": {
        "fixed": {
          "position": "fixed",
          "bottom": "var(--space-24)",
          "left": "50%",
          "transform": "translateX(-50%)",
          "background": "c6",
          "color": "bg",
          "padding": "var(--space-8) var(--space-16)",
          "border-radius": "var(--radius-md)",
          "font-family": "mono",
          "font-size": "0.75rem"
        },
        "notification": {
          "colors": {
            "ok":    { "hex": "#39ff14", "token": "c2", "role": "success" },
            "err":   { "hex": "#ff3864", "token": "c1", "role": "error" },
            "warn":  { "hex": "#fcee09", "token": "c3", "role": "warning" },
            "info":  { "hex": "#00aaff", "token": "c4", "role": "info" }
          }
        }
      }
    }
  },

  "rules": {
    "description": "Usage guidelines for applying the palette. From the 'Using it well' section.",
    "do": [
      "Keep backgrounds in the void range and let foreground text breathe.",
      "Pick one lead hue per surface as the dominant accent.",
      "Reserve cyan for focus, cursor, and the single active element.",
      "Map color to meaning consistently across every screen.",
      "Lean on glow for emphasis, not as a baseline texture."
    ],
    "dont": [
      "Put two saturated hues at equal weight competing for the eye.",
      "Use green as a general accent; it reads as success and nothing else.",
      "Glow every element. The effect dies when it is everywhere.",
      "Drop pure flag-green or pure brown straight in; they clash with the neon set.",
      "Place body text in a neon hue. Foreground lavender carries the words."
    ]
  },

  "states": {
    "description": "Interactive component states: disabled, loading, empty.",
    "disabled": {
      "description": "Applied via :disabled or [aria-disabled='true']. Reduces visual weight without removing the element from layout.",
      "opacity": 0.35,
      "cursor": "not-allowed",
      "pointer-events": "none",
      "note": "Buttons also get filter: grayscale(0.6). Inputs get background: var(--elev) and border-color: var(--line-soft)."
    },
    "loading": {
      "description": "Applied via .is-loading on buttons or .spinner / .skeleton for content placeholders.",
      "button": {
        "class": "is-loading",
        "behavior": "Hides text via color: transparent, overlays a CSS border-spinner via ::before"
      },
      "spinner": {
        "class": "spinner",
        "style": "1em circle, 1.5px border, 0.6s spin animation, currentColor for the visible arc"
      },
      "skeleton": {
        "class": "skeleton",
        "style": "Shimmer gradient (elev → raised → elev), 1.5s animation, --radius-sm",
        "variants": {
          "default": "0.9rem height, full width, last-child 60%",
          "bar": "skeleton-bar: 30% width, 0.8rem height",
          "block": "skeleton-block: 4rem height"
        }
      }
    },
    "empty": {
      "description": "Applied via .empty-state. Shows a centered placeholder when a list, panel, or view has no content.",
      "class": "empty-state",
      "style": "flex column centered, var(--space-32)/var(--space-24) padding, dashed border, var(--radius-lg)",
      "children": {
        "icon": "2rem font-size, 0.4 opacity",
        "title": "mono, 0.78rem, uppercase, letter-spacing 0.08em, muted",
        "desc": "0.82rem, muted, max-width 24rem"
      }
    }
  }
}
